%====================================================================================
% Estrutura de Documentação Externa
%====================================================================================

%====================================================================================
% \Documentacao % inicia a documentação
%====================================================================================
\newcommand{\Documentacao}{
  \textsc{Documenta\c{c}\~ao}\\[\myskip]
  \forwardi
}

%====================================================================================
% \FimDocumentacao % encerra a documentação
%====================================================================================
\newcommand{\FimDocumentacao}{
  \backwardi
  \textsc{Fim Documenta\c{c}\~ao}\\[\myskip]
}

%====================================================================================
% \Titulo{<identificador (o que?)>}
%====================================================================================
\newcommand{\Titulo}[1]{
  \partab\textsc{T\'itulo}\\[\myskip]
  \partab\inctab\parbox[t]{\textwidth-2\tab}{\textbf{#1}}\\[\myskip]
}

%====================================================================================
% \Proposito{<objetivo (para que?)>}
%====================================================================================
\newcommand{\Proposito}[1]{
  \partab\textsc{Prop\'osito}\\[\myskip]
  \partab\inctab\parbox[t]{\textwidth-2\tab}{#1}\\[2\myskip]
}

%====================================================================================
% \Metodologia{<lógica (como?)>}
%====================================================================================
\newcommand{\Metodologia}[1]{
  \partab\textsc{M\'etodo}\\[\myskip]
  \partab\inctab\parbox[t]{\textwidth-2\tab}{#1}\\[2\myskip]
}

\newlength{\mao}
\setlength{\mao}{7\tab}

%====================================================================================
% \Entradas{<lista de identificadores>}
%====================================================================================
\newcommand{\Entradas}[2][]{
  \ifnotempty{#1}{\setlength{\mao}{#1}}%
  \partab\textsc{Entradas}\\[\myskip]
  \partab\inctab{\parbox[t]{\textwidth-2\tab}{#2}}\\[2\myskip]
}

%====================================================================================
% \Saidas{<lista de identificadores>}
%====================================================================================
\newcommand{\Saidas}[2][]{
  \ifnotempty{#1}{\setlength{\mao}{#1}}%
  \partab\textsc{Sa\'idas}\\[\myskip]
  \partab\inctab{\parbox[t]{\textwidth-2\tab}{#2}}\\[2\myskip]
}

%====================================================================================
% \Dados[<largura da caixa de dados>]{<definições>}
%====================================================================================
\newcommand{\Dados}[2][]{
  \ifnotempty{#1}{\setlength{\mao}{#1}}%
  \partab\textsc{Dados}\\[\myskip]
  \partab\inctab{\parbox[t]{\textwidth-2\tab}{#2}}\\[2\myskip]
}

%====================================================================================
% \DadoDefinicao[<largura da coluna do identificador>]{<identificador>}{<definição>}
%====================================================================================
\newcommand{\DadoDefinicao}[3][]{%
  \ifnotempty{#1}{\setlength{\mao}{#1}}%
    {\parbox[t]{\mao}{#2}}%
    {\parbox[t]{\textwidth-\mao-2.5\tab}{#3}}\\[2\myskip]
}

%====================================================================================
% \Observacoes{<requisitos e restrições (dependências e limites?)>}
%====================================================================================
\newcommand{\Observacoes}[1]{
  \partab\textsc{Observa\c{c}\~oes, Restri\c{c}\~oes, Requisitos}\\[\myskip]
  \partab\inctab\parbox[t]{\textwidth-2\tab}{#1}\\[2\myskip]
}

