\newcommand{\algorithmname}{Algoritmo}

\newcounter{algorithm}
\renewcommand \thealgorithm {\@arabic\c@algorithm}

\newcounter{pseudocode}[algorithm]
\renewcommand \thepseudocode {\thealgorithm\@alph\c@pseudocode}
%\counterwithin{pseudocode}{algorithm}

\newcounter{pseudocounter}

\newenvironment{pseudocode}
  {\setcounter{contlin}{0}%
   \setcounter{conttab}{0}%
   \setcounter{contitab}{0}%
   \refstepcounter{pseudocode}%
   \setcounter{pseudocounter}{\c@pseudocode}%
   \rule{\textwidth}{.4pt}\par%
   \pseudocodefontsize\singlespacing\vspace{5pt}\begingroup}
  {\endgroup\rule{\textwidth}{.4pt}}

\newenvironment{pseudocode*}
  {\setcounter{pseudocode}{\c@pseudocounter}%
   \refstepcounter{pseudocode}%
   \setcounter{pseudocounter}{\c@pseudocode}%
   \ifbool{oldop}%
      {\comlinhanumerada}%
      {\semlinhanumerada}%
   \rule{\textwidth}{.4pt}\par%
   \pseudocodefontsize\singlespacing\vspace{5pt}\begingroup}
  {\endgroup\rule{\textwidth}{.4pt}}

\def\fps@algorithm{htbp}
\def\ftype@algorithm{3}
\def\ext@algorithm{loa}
\def\fnum@algorithm{\algorithmname\nobreakspace\thealgorithm}

